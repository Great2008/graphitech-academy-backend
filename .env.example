# Copy to .env and fill in real values. Never commit .env itself.

# --- Database (Supabase Postgres connection string) ---
DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/graphitech_academy

# --- Auth ---
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# --- AI ---
GROQ_API_KEY=
ANTHROPIC_API_KEY=

# --- Payments (Paystack) ---
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=

# --- Supabase storage ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=graphitech-academy

# --- Coding playground ---
JUDGE0_API_URL=
JUDGE0_API_KEY=

# --- AI tutor free-tier limit ---
TUTOR_FREE_DAILY_LIMIT=15

# --- App ---
ENVIRONMENT=development
FRONTEND_URL=http://localhost:5173
